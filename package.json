{
  "name": "agentui",
  "displayName": "AgentUI",
  "version": "0.0.1",
  "description": "Browser extension foundation for AgentUI",
  "author": "tisanmoreno",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "plasmo": "0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@types/chrome": "0.1.39",
    "@types/node": "25.5.2",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "typescript": "5.8.2"
  },
  "manifest": {
    "host_permissions": [
      "http://*/*",
      "https://*/*"
    ],
    "permissions": [
      "storage"
    ]
  }
}
